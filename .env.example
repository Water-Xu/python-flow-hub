# ============ PyFlowHub 控制面环境变量示例 ============
# 复制为 .env 后按需修改；生产环境敏感值由 K8s Secret / Secret Manager 注入

# 运行模式：local（dev 本地 Docker 沙箱执行）| k8s（生产经 K8s API 编排）
PYFLOW_DEPLOYMENT_MODE=local

# 独立 PostgreSQL 库（决策 8：不与现有 ums_*/ai_outfit 同库）
PYFLOW_DB_DSN=postgresql+asyncpg://pyflow:pyflow@localhost:5432/pyflow

# Redis（Cluster 仅 DB0；本地用单机 redis 即可）
PYFLOW_REDIS_URL=redis://localhost:6379/0
PYFLOW_REDIS_CLUSTER=false

# RabbitMQ（vhost=/lhy-styon）
PYFLOW_RABBITMQ_URL=amqp://pyflow:pyflow@localhost:5672//lhy-styon

# MinIO（版本大字段存储）
PYFLOW_MINIO_ENDPOINT=localhost:9000
PYFLOW_MINIO_ACCESS_KEY=minioadmin
PYFLOW_MINIO_SECRET_KEY=minioadmin
PYFLOW_MINIO_SECURE=false
PYFLOW_MINIO_BUCKET=pyflow-versions

# Sa-Token 鉴权服务（1b 起生效；1a 用 dev 默认用户兜底）
PYFLOW_SATOKEN_VERIFY_URL=http://lhy-styon-gateway:8201/lhy-styon-auth/token/verify
PYFLOW_AUTH_ENABLED=false
PYFLOW_DEV_DEFAULT_LOGIN_ID=dev-admin

# 首个 ADMIN bootstrap（决策 2）
PYFLOW_BOOTSTRAP_ADMIN=dev-admin

# 可观测性（决策 13）
PYFLOW_OTLP_ENDPOINT=http://otel-collector:4318
PYFLOW_GCP_PROJECT=lhy-styon-dev-4832

# Docker 沙箱（dev local，deployment_mode=local 时）
PYFLOW_DOCKER_BASE_IMAGE=python:3.11-slim
PYFLOW_SANDBOX_GVISOR=false

# GKE 执行（deployment_mode=k8s 时，经 K8s Job 拉 runner 镜像，勿挂 docker.sock）
# PYFLOW_K8S_NAMESPACE=pyflow-blocks
# PYFLOW_RUNNER_IMAGE=us-central1-docker.pkg.dev/lhy-styon-dev-4832/lhy-styon/pyflow-runner:latest

# ============ 块运行时中间件接入（让中台启动的 Flow / 调用块连 redis/mq/db） ============
# 部署时自动渲染共享 Secret(pyflow-block-middleware) 注入每个块(envFrom)，并放行 NetworkPolicy egress。
# 块内 Python 代码按约定环境变量读取：REDIS_URL / RABBITMQ_URL / DATABASE_URL / MINIO_ENDPOINT / MINIO_ACCESS_KEY / MINIO_SECRET_KEY
PYFLOW_BLOCK_INJECT_MIDDLEWARE=true
PYFLOW_BLOCK_MIDDLEWARE_SECRET=pyflow-block-middleware
# 中间件所在命名空间 + 放行端口（RabbitMQ/MinIO/ES/Nacos 都在 lhy-styon）
PYFLOW_MIDDLEWARE_NAMESPACE=lhy-styon
PYFLOW_MIDDLEWARE_NS_PORTS=5672,15672,9000,9001,9200,8848,19530,6379
# Milvus 向量库（块读 MILVUS_URI；空则不注入）
# PYFLOW_BLOCK_MILVUS_URI=http://milvus.lhy-styon.svc.cluster.local:19530
# VPC 私网中间件 egress 白名单（Cloud SQL）：cidr:port 逗号分隔
PYFLOW_BLOCK_EGRESS_CIDRS=10.196.0.3/32:5432
# 块连接默认复用控制面同一套；如需块连业务库/独立 redis 可单独指定（留空回退控制面）：
# PYFLOW_BLOCK_DB_DSN=postgresql://lhy_app:***@10.196.0.3:5432/ai_outfit
# PYFLOW_BLOCK_REDIS_URL=redis://redis.lhy-styon.svc.cluster.local:6379/0
# PYFLOW_BLOCK_RABBITMQ_URL=amqp://lhy-styon:***@rabbitmq.lhy-styon.svc.cluster.local:5672//lhy-styon

# ============ GCP / GKE 中间件连接速查（lhy-styon-dev 集群，us-central1-a）============
#   PostgreSQL(业务)     jdbc/dsn  <CLOUD_SQL_PRIVATE_IP>:5432/ai_outfit     用户 lhy_app    实例 lhy-styon-pg
#   PostgreSQL(pyflow)   dsn       <CLOUD_SQL_PRIVATE_IP>:5432/pyflow        用户 pyflow     同实例独立库
#   Redis Cluster        host      redis.lhy-styon.svc.cluster.local:6379   无密码          K8s 自部署 Cluster
#   RabbitMQ             amqp      rabbitmq.lhy-styon.svc.cluster.local:5672 用户 lhy-styon  vhost /lhy-styon
#   RabbitMQ Management  http      rabbitmq.lhy-styon.svc.cluster.local:15672 同上           KEDA 读队列深度
#   MinIO                http      minio.lhy-styon.svc.cluster.local:9000    用户 minioadmin bucket pyflow-versions
#   Elasticsearch        http      elasticsearch.lhy-styon.svc.cluster.local:9200  无认证
#   Nacos                http      nacos-registry.lhy-styon.svc.cluster.local:8848 用户 nacos
#   Milvus               grpc      milvus.lhy-styon.svc.cluster.local:19530          无认证(Standalone)
#   OTel Collector       http      otel-collector.lhy-styon.svc.cluster.local:4318 Workload Identity
#   注：pyflow 在 pyflow-blocks 命名空间，访问 lhy-styon 中间件必须用上面的跨命名空间 FQDN。
